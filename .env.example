# Copy to .env and fill in. mathagent auto-loads this file; LiteLLM reads the keys.
# Pick ONE backend (or set several and switch with --model / MATHAGENT_MODEL).
# Model names use LiteLLM's "provider/model" form.

# --- OpenRouter (one key, many models) ---
MATHAGENT_MODEL=openrouter/anthropic/claude-sonnet-4.6
OPENROUTER_API_KEY=sk-or-v1-...
#   other good math models: openrouter/deepseek/deepseek-r1-0528,
#   openrouter/qwen/qwen3-235b-a22b-thinking-2507, openrouter/anthropic/claude-opus-4.8

# --- or a direct provider (set only what you use) ---
# MATHAGENT_MODEL=anthropic/claude-sonnet-4.6
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=...
# self-hosted / HPC vLLM (openai-compatible):
#   MATHAGENT_MODEL=openai/<served-model-name>
#   OPENAI_API_BASE=http://<host>:<port>/v1
#   OPENAI_API_KEY=dummy
