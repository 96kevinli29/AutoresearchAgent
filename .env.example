# Copy to .env and fill in. LiteLLM reads these automatically.
# Pick ONE backend (or set several and switch with --model / MATHAGENT_MODEL).

# Default model (LiteLLM "provider/model" form):
MATHAGENT_MODEL=anthropic/claude-opus-4-6

# --- credentials (set only what you use) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=...
# For a self-hosted / HPC vLLM endpoint, use the openai-compatible route:
#   MATHAGENT_MODEL=openai/<served-model-name>
#   OPENAI_API_BASE=http://<host>:<port>/v1
#   OPENAI_API_KEY=dummy
